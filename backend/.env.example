APP_NAME=Fashion Inspiration API
APP_ENV=development
CORS_ORIGINS=["http://localhost:3000"]

# Leave unset for SQLite (uses database_path). For Postgres:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/fashion
# When you run `uvicorn` from the `backend/` folder, use paths relative to that folder:
DATABASE_PATH=data/library.db

# Match where uvicorn listens (no trailing slash) so /static/uploads/... URLs resolve in the browser.
PUBLIC_ASSETS_BASE_URL=http://localhost:8000

# local | s3
STORAGE_BACKEND=local
STORAGE_ROOT=data

# S3 (when STORAGE_BACKEND=s3)
# S3_BUCKET=my-bucket
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT_URL=

# heuristic | openai
CLASSIFIER_BACKEND=heuristic
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# sync | background | arq
CLASSIFICATION_EXECUTION=sync
# REDIS_URL=redis://localhost:6379

LOG_LEVEL=INFO
SEED_DEMO_DATA=true
